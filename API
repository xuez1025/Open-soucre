            SavedDisplayName = username -- 預設顯示名稱
        }

        task.spawn(function()
            local userRes = sendRequest({
                Url = "https://users.roproxy.com/v1/usernames/users",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({ usernames = { username }, excludeBannedUsers = false })
            })

            if userRes and userRes.StatusCode == 200 then
                local uData = HttpService:JSONDecode(userRes.Body).data[1]
                if uData then
                    local userId = uData.id
                    monitoredPlayers[username].UserId = userId
                    AvatarImg.Image = string.format("https://www.roproxy.com/headshot-thumbnail/image?userId=%s&width=150&height=150&format=png", tostring(userId))

                    local detailRes = sendRequest({
                        Url = "https://users.roproxy.com/v1/users/" .. tostring(userId),
                        Method = "GET"
                    })

                    if detailRes and detailRes.StatusCode == 200 then
                        local detail = HttpService:JSONDecode(detailRes.Body)
                        local hasBadge = detail.hasVerifiedBadge or false
                        VerifiedIcon.Visible = hasBadge
                        
                        -- 儲存顯示名稱供 Webhook 提取
                        monitoredPlayers[username].SavedDisplayName = detail.displayName
                        
                        -- 完美換行模板整合
                        monitoredPlayers[username].StaticTextTemplate = 
                            "暱稱: " .. detail.displayName .. "\n" ..
                            "名稱: " .. detail.name .. "\n" ..
                            "ID: " .. tostring(userId)
                            
                        InfoLabel.Text = monitoredPlayers[username].StaticTextTemplate
                    end
                end
            else
                InfoLabel.Text = "❌ 找不到此玩家\n或 API 故障。"
            end
        end)
    end
    LeftContainer.CanvasSize = UDim2.new(0, 0, 0, #targetUsers * 122 + 20)
end

