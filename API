local function showDetailByUserId(userId)
    DetailVerified.Visible = false
    DetailAvatar.Image = "https://www.roproxy.com/headshot-thumbnail/image?userId=" .. tostring(userId) .. "&width=150&height=150&format=png"
    DetailText.Text = "⏳ 正在同步雲端深度數據..."
    
    currentSelectedId = userId

    task.spawn(function()
        local detailRes = sendRequest({
            Url = "https://users.roproxy.com/v1/users/" .. tostring(userId),
            Method = "GET"
        })
        local presenceRes = sendRequest({
            Url = "https://presence.roproxy.com/v1/presence/users",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ userIds = { tonumber(userId) } })
        })

        if detailRes and detailRes.StatusCode == 200 then
            local detail = HttpService:JSONDecode(detailRes.Body)
            
            currentSelectedName = detail.name
            
            local isVerified = detail.hasVerifiedBadge or false
            DetailVerified.Visible = isVerified
            local verifiedString = isVerified and "已驗證 ✅ (Verified)" or "未驗證 ❌"
            
            local statusText = "離線 (Offline)"
            local extraGameInfo = ""
            
            if presenceRes and presenceRes.StatusCode == 200 then
                local pInfo = HttpService:JSONDecode(presenceRes.Body).userPresences[1]
                if pInfo then
                    local pType = pInfo.userPresenceType
                    if pType == 1 then 
                        statusText = "🌐 線上 (大廳/網頁)"
                    elseif pType == 2 then 
                        statusText = "🎮 遊戲中 (In-Game)"
                        local gName = getPlaceName(pInfo.placeId)
                        local pId = pInfo.placeId and tostring(pInfo.placeId) or "無"
                        
                        if pInfo.gameId and pInfo.gameId ~= "" then
                            extraGameInfo = string.format("\n\n[ 🎮 當前伺服器 ]\n● 遊戲名稱: %s\n● PlaceID: %s\n● 追隨狀態: 開放 ✅", gName, pId)
                        else
                            extraGameInfo = string.format("\n\n[ 🎮 當前伺服器 ]\n● 遊戲名稱: %s\n● PlaceID: %s\n● 追隨狀態: 隱私封鎖 ❌", gName, pId)
                        end
                    elseif pType == 3 then 
                        statusText = "🛠️ Studio 編輯中"
                    end
                end
            end

            DetailText.Text = string.format(
                "[ 📝 帳號基礎資訊 ]\n" ..
                "● 玩家名稱: %s\n" ..
                "● 使用者ID: %s\n" ..
                "● 顯示暱稱: %s\n" ..
                "● 驗證狀態: %s\n" ..
                "● 註冊日期: %s\n\n" ..
                "-[ 📡 當前活動狀態 ]\n" ..
                "● 狀態: %s%s\n\n" ..
                "[ 🏷️ 個人簡介 ]\n%s",
                detail.name,
                tostring(userId),
                detail.displayName,
                verifiedString,
                detail.created:sub(1, 10),
                statusText,
                extraGameInfo,
                (detail.description == "" and "(該使用者沒有填寫簡介)" or detail.description)
            )
        else
            DetailText.Text = "❌ 無法取得該玩家的詳細資料，API 請求被阻斷。"
            currentSelectedName = ""
            currentSelectedId = nil
        end
    end)
end

