-- 搜尋處理
---------------------------------------------
local function handleSearch()
    local text = SearchBox.Text:gsub("%s+", "")
    if text == "" then return end
    
    if tonumber(text) then
        showDetailByUserId(tonumber(text))
    else
        DetailText.Text = "⚡ 正在檢索該玩家 ID 對應檔案..."
        task.spawn(function()
            local res = sendRequest({
                Url = "https://users.roproxy.com/v1/usernames/users",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({ usernames = { text }, excludeBannedUsers = false })
            })
            if res and res.StatusCode == 200 then
                local data = HttpService:JSONDecode(res.Body).data[1]
                if data then
                    showDetailByUserId(data.id)
                else
                    DetailText.Text = "❌ 資料庫中查無此玩家，請確認拼字。"
                end
            else
                DetailText.Text = "❌ 遠端 API 請求失敗。"
            end
        end)
    end
end

SearchBtn.MouseButton1Click:Connect(handleSearch)
SearchBox.FocusLost:Connect(function(enterPressed) if enterPressed then handleSearch() end end)
applyHoverEffect(SearchBtn, Color3.fromRGB(56, 110, 245), Color3.fromRGB(46, 95, 220))

---------------------------------------------
-- 定時刷新輪詢 (5秒)
---------------------------------------------
local function startPresenceLoop()
    task.spawn(function()
        while MainFrame and MainFrame.Parent do
            for i = 5, 1, -1 do
                if not MainFrame.Visible then task.wait(1) else
                    TitleLabel.Text = string.format("🛰️ MULTI-MONITOR SYSTEM [ ⏳ 00:0%d 後自動更新 ]", i)
                    task.wait(1)
                end
            end
            if MainFrame.Visible then
                TitleLabel.Text = "🛰️ MULTI-MONITOR SYSTEM ( 🔄 同步雲端數據中... )"
            end

            local idList = {}
            local nameMap = {}
            for name, pData in pairs(monitoredPlayers) do
                if pData.UserId then
                    table.insert(idList, pData.UserId)
                    nameMap[tostring(pData.UserId)] = name
                end
            end

            if #idList > 0 then
                local presenceRes = sendRequest({
                    Url = "https://presence.roproxy.com/v1/presence/users",
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = HttpService:JSONEncode({ userIds = idList })
                })

                if presenceRes and presenceRes.StatusCode == 200 then
                    local presences = HttpService:JSONDecode(presenceRes.Body).userPresences
                    for _, pInfo in ipairs(presences) do
                        local targetName = nameMap[tostring(pInfo.userId)]
                        local pData = monitoredPlayers[targetName]

                        if pData then
                            local pType = pInfo.userPresenceType
                            local statusText = "離線"
                            local statusColor = Color3.fromRGB(130, 135, 150)

                            if pType == 0 then
                                statusText = "離線"
                                statusColor = Color3.fromRGB(130, 135, 150)
                            elseif pType == 1 then
                                statusText = "線上"
                                statusColor = Color3.fromRGB(56, 140, 255)
                            elseif pType == 2 then
                                statusText = "遊戲中"
                                statusColor = Color3.fromRGB(46, 204, 113)
                            elseif pType == 3 then
                                statusText = "Studio"
                                statusColor = Color3.fromRGB(241, 196, 15)
                            end

                            TweenService:Create(pData.StatusDot, TweenInfo.new(0.3), {BackgroundColor3 = statusColor}):Play()
                            pData.StatusLabel.Text = statusText
                            pData.StatusLabel.TextColor3 = statusColor

                            if pData.StaticTextTemplate then
                                if pType == 2 then
                                    task.spawn(function()
                                        local gameName = getPlaceName(pInfo.placeId)
                                        pData.InfoLabel.Text = pData.StaticTextTemplate .. string.format("\n🎮 當前活動: %s", gameName)
                                    end)
                                else
                                    pData.InfoLabel.Text = pData.StaticTextTemplate
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

