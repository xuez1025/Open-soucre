-- 【核心 Presence 刷新循環：10人一批佇列掃描，提供全域統計且絕不卡死】
local function startPresenceLoop()
    task.spawn(function()
        while MainFrame and MainFrame.Parent do
            -- 倒數計時顯示，整合全域在線數統計
            for i = 5, 1, -1 do
                if not MainFrame.Visible then task.wait(1) else
                    TitleLabel.Text = string.format(" 管理員&主播上線狀態 (🎮 遊戲中: %d / 總計: %d 位) [ ⏳ %d 秒後刷新 ]", globalInGameCount, totalMonitoredCount, i)
                    task.wait(1)
                end
            end
            if MainFrame.Visible then
                TitleLabel.Text = string.format(" 管理員&主播上線狀態 (🎮 遊戲中: %d / 總計: %d 位) ( 🔄 加載數據中... )", globalInGameCount, totalMonitoredCount)
            end

            -- 收集目前所有已經成功獲取到 ID 的名單
            local allIds = {}
            local nameMap = {}
            for _, name in ipairs(targetUsers) do
                local pData = monitoredPlayers[name]
                if pData and pData.UserId then
                    table.insert(allIds, pData.UserId)
                    nameMap[tostring(pData.UserId)] = name
                end
            end

            local allPresences = {}

            -- 【高階優化方案】：將全體名單每 10 人分為一組，分批發送 API 請求，完美迴避當機問題
            if #allIds > 0 then
                for batchStart = 1, #allIds, 10 do
                    local batchIds = {}
                    for j = batchStart, math.min(batchStart + 9, #allIds) do
                        table.insert(batchIds, allIds[j])
                    end

                    local presenceRes = sendRequest({
                        Url = "https://presence.roproxy.com/v1/presence/users",
                        Method = "POST",
                        Headers = { ["Content-Type"] = "application/json" },
                        Body = HttpService:JSONEncode({ userIds = batchIds })
                    })

                    if presenceRes and presenceRes.StatusCode == 200 then
                        local userPresences = HttpService:JSONDecode(presenceRes.Body).userPresences
                        for _, pInfo in ipairs(userPresences) do
                            table.insert(allPresences, pInfo)
                        end
                    end
                    task.wait(0.1) -- 每 10 人的請求間進行極微小喘息，保證效能流暢、絕不爆 API
                end
            end

            -- 當完整獲取完全部批次的狀態後，開始統一更新數據
            if #allPresences > 0 then
                local currentTime = os.time()
                local shouldSendWebhook = false
                local inGamePlayersThisCycle = {}
                local tempInGameCounter = 0 -- 暫時用來統計這輪的全域遊戲中人數

                -- 第一輪遍歷：更新所有卡片的緩存狀態
                for _, pInfo in ipairs(allPresences) do
                    local targetName = nameMap[tostring(pInfo.userId)]
                    local pData = monitoredPlayers[targetName]

                    if pData then
                        local pType = pInfo.userPresenceType
                        pData.currentPresenceType = pType 
                        
                        local statusText = "離線"
                        local statusColor = Color3.fromRGB(130, 135, 150)

                        if pType == 0 then
                            statusText = "離線"
                            statusColor = Color3.fromRGB(130, 135, 150)
                        elseif pType == 1 then
                            statusText = "線上"
                            statusColor = Color3.fromRGB(56, 140, 255)
                        elseif pType == 2 then
                            statusText = "遊戲中"
                            statusColor = Color3.fromRGB(46, 204, 113)
                            tempInGameCounter = tempInGameCounter + 1 -- 全域計數累加
                        elseif pType == 3 then
                            statusText = "Studio"
                            statusColor = Color3.fromRGB(241, 196, 15)
                        end

                        TweenService:Create(pData.StatusDot, TweenInfo.new(0.3), {BackgroundColor3 = statusColor}):Play()
                        pData.StatusLabel.Text = statusText
                        pData.StatusLabel.TextColor3 = statusColor

                        if pData.StaticTextTemplate then
                            if pType == 2 then
                                task.spawn(function()
                                    local gameName = getPlaceName(pInfo.placeId)
                                    pData.InfoLabel.Text = pData.StaticTextTemplate .. string.format("\n🎮 當前活動: %s", gameName)
                                end)
                            else
                                pData.InfoLabel.Text = pData.StaticTextTemplate
                            end
                        end

                        -- 【核心 Webhook 發送控制邏輯】
                        if pType == 2 then
                            table.insert(inGamePlayersThisCycle, pData)
                            local lastNotifyTime = pData.lastNotificationTime or 0
                            if not pData.lastInGameStatus or (currentTime - lastNotifyTime >= 180) then
                                shouldSendWebhook = true
                            end
                        end
                    end
                end

                -- 更新全域數值，供下一次計時器渲染
                globalInGameCount = tempInGameCounter

                -- 即時刷新當前頁面排版（包含過濾器邏輯自動反應）
                updatePage()

                -- Webhook 整合發送機制
                if shouldSendWebhook and #inGamePlayersThisCycle > 0 and webhookUrl ~= "" then
                    local messageLines = {}

                    if isPingEnabled and pingId ~= "" then
                        local pingStr, valid = formatPing(pingId)
                        if valid and pingStr then
                            table.insert(messageLines, pingStr)
                        end
                    end

                    for _, pData in ipairs(inGamePlayersThisCycle) do
                        local dName = pData.SavedDisplayName or pData.Card.Name
                        local uName = pData.Card.Name
                        local uId = pData.UserId and tostring(pData.UserId) or "未知"
                        
                        local formattedItem = string.format("```%s(%s)在遊戲中```\n透過主頁加入他吧！\nhttps://www.roblox.com/users/%s/profile", dName, uName, uId)
                        table.insert(messageLines, formattedItem)
                        pData.lastNotificationTime = currentTime
                    end

                    local finalPayload = table.concat(messageLines, "\n\n")
                    SendWebhook(webhookUrl, finalPayload)
                end

                -- 第二輪遍歷：狀態同步
                for _, pInfo in ipairs(allPresences) do
                    local targetName = nameMap[tostring(pInfo.userId)]
                    local pData = monitoredPlayers[targetName]
                    if pData then
                        pData.lastInGameStatus = (pInfo.userPresenceType == 2)
                    end
                end

            end
        end
    end)
end

