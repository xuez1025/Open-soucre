-- 核心邏輯：複製到剪貼簿的相容性函式
---------------------------------------------
local function copyToClipboard(text)
    local setClipboard = setclipboard or toclipboard or (syn and syn.write_clipboard)
    if setClipboard then
        setClipboard(text)
        return true
    else
        return false
    end
end

---------------------------------------------
-- 核心邏輯：獲取 UserID 的通用函式
---------------------------------------------
local function getUserId(target, callback)
    if tonumber(target) ~= nil then
        callback(target)
        return
    end
    ResultText.Text = "正在查詢玩家 ID，請稍候..."
    task.spawn(function()
        local requestFunc = syn and syn.request or http_request or request
        if not requestFunc then
            ResultText.Text = "錯誤: 執行器不支援 request 函數，無法轉換名稱。"
            return
        end
        local success, res = pcall(function()
            return requestFunc({
                Url = "https://users.roproxy.com/v1/usernames/users",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({ usernames = { target }, excludeBannedUsers = false })
            })
        end)
        if success and res.StatusCode == 200 then
            local data = HttpService:JSONDecode(res.Body)
            if data and data.data and data.data[1] then
                callback(data.data[1].id)
            else
                ResultText.Text = "錯誤: 找不到該玩家，請檢查名稱是否拼錯。"
            end
        else
            ResultText.Text = "錯誤: 玩家 ID 查詢失敗（RoProxy 伺服器異常）。"
        end
    end)
end

---------------------------------------------
-- 核心邏輯：發送請求（已改為單次執行，無循環）
---------------------------------------------
local function performApiRequest()
    if currentTargetUrl == "" then return end
    
    local targetUrl = currentTargetUrl:gsub("roblox%.com", "roproxy.com")
    ResultText.Text = "正在發送請求..."
    
    task.spawn(function()
        local success, res
        if currentMethod == "GET" then
            success, res = pcall(function() return game:HttpGetAsync(targetUrl) end)
        else
            local requestFunc = syn and syn.request or http_request or request
            if not requestFunc then
                ResultText.Text = "錯誤: 執行器缺少 request 函數，無法發送 POST 請求。"
                return
            end
            success, res = pcall(function()
                local response = requestFunc({
                    Url = targetUrl,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = currentBody
                })
                return response.Body
            end)
        end
        
        if success then
            lastRawResponse = res -- 緩存原始資料供複製解析用
            
            -- 使用 Pretty Print 格式化
            local status, cleanJson = pcall(function()
                local decoded = HttpService:JSONDecode(res)
                return HttpService:JSONEncode(decoded) 
            end)
            
            local formattedResult = res
            if status then
                local decoded = HttpService:JSONDecode(res)
                -- 修正原始排版替換邏輯，移除亂碼字元
                formattedResult = HttpService:JSONEncode(decoded):gsub(',', ',\n    '):gsub('{', '{\n    '):gsub('}', '\n}')
            end
            
            local timestamp = os.date("%X")
            ResultText.Text = "【手動更新成功: " .. timestamp .. "】\n" .. formattedResult
        else
            ResultText.Text = "請求失敗:\n" .. tostring(res)
        end
    end)
end

