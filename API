-- [ 核心功能 ] Discord Webhook 發送與驗證函式
local function SendWebhook(url, msg)
    local data = {
        username = "Xu bot",
        avatar_url = "https://files.catbox.moe/qfuvqz.jpg",
        content = msg
    }

    local HttpService = game:GetService("HttpService")
    local body = HttpService:JSONEncode(data)

    local requestFunc = (syn and syn.request) 
        or (http and http.request) 
        or (fluxus and fluxus.request) 
        or request

    if requestFunc then
        requestFunc({
            Url = url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = body
        })
        if WindUI and WindUI.Notify then
            WindUI:Notify({ Title = "通知", Content = "訊息已嘗試送出！", Duration = 2 })
        end
    else
        if WindUI and WindUI.Notify then
            WindUI:Notify({ Title = "錯誤", Content = "此 Executor 不支援 HTTP Request", Duration = 3 })
        end
    end
end

local function formatPing(pingInput)
    pingInput = pingInput:gsub("%s+", "")
    
    if pingInput == "" then 
        return "@everyone ", true
    end
    
    if pingInput == "everyone" or pingInput == "here" then
        return "@" .. pingInput .. " ", true
    end
    
    if tonumber(pingInput) then
        return "<@" .. pingInput .. "> ", true
    end
    
    if pingInput:sub(1,1) == "&" then
        local roleId = pingInput:sub(2)
        if tonumber(roleId) then
            return "<@&" .. roleId .. "> ", true
        end
    end
    
    return nil, false
end

