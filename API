local function getPlaceName(placeId)
    if not placeId or placeId == 0 or placeId == "無" or placeId == "" then return "未知遊戲場景" end
    local success, result = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(placeId)).Name
    end)
    return success and result or "不公開的私有場景"
end

local function makeDraggable(dragTarget, dragTrigger)
    local dragging, dragInput, dragStart, startPos
    dragTrigger.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = dragTarget.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragTrigger.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            dragTarget.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

