-- 【分頁與過濾器更新核心函式】
local function updatePage()
    if isFilterInGame then
        PrevPageBtn.Visible = false
        NextPageBtn.Visible = false
        PageLabel.Position = UDim2.new(0, 0, 0, 0)
        PageLabel.Size = UDim2.new(1, 0, 1, 0)
        PageLabel.Text = "（無分頁限制）"

        local visibleCount = 0
        for _, username in ipairs(targetUsers) do
            local pData = monitoredPlayers[username]
            if pData and pData.Card then
                if pData.currentPresenceType == 2 then 
                    pData.Card.Visible = true
                    visibleCount = visibleCount + 1
                else
                    pData.Card.Visible = false
                end
            end
        end
        LeftContainer.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 122 + 20)
    else
        PrevPageBtn.Visible = true
        NextPageBtn.Visible = true
        PageLabel.Position = UDim2.new(0, 250, 0, 0)
        PageLabel.Size = UDim2.new(1, -350, 1, 0)

        local totalPages = math.ceil(#targetUsers / itemsPerPage)
        if totalPages == 0 then totalPages = 1 end
        
        if currentPage > totalPages then currentPage = totalPages end
        if currentPage < 1 then currentPage = 1 end
        
        PageLabel.Text = string.format("第 %d / %d 頁", currentPage, totalPages)
        
        local startIndex = (currentPage - 1) * itemsPerPage + 1
        local endIndex = currentPage * itemsPerPage
        
        for index, username in ipairs(targetUsers) do
            local pData = monitoredPlayers[username]
            if pData and pData.Card then
                if index >= startIndex and index <= endIndex then
                    pData.Card.Visible = true
                else
                    pData.Card.Visible = false 
                end
            end
        end
        
        local currentlyVisibleCount = math.min(itemsPerPage, #targetUsers - startIndex + 1)
        if currentlyVisibleCount < 0 then currentlyVisibleCount = 0 end
        LeftContainer.CanvasSize = UDim2.new(0, 0, 0, currentlyVisibleCount * 122 + 20)
    end
end

-- 【優化：分批排隊獲取名單 ID，10人一組，絕不卡頓當機】
local function resolveAllUserIdsInBatches()
    task.spawn(function()
        for i = 1, #targetUsers, 10 do
            local batchNames = {}
            for j = i, math.min(i + 9, #targetUsers) do
                table.insert(batchNames, targetUsers[j])
            end
            
            local userRes = sendRequest({
                Url = "https://users.roproxy.com/v1/usernames/users",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({ usernames = batchNames, excludeBannedUsers = false })
            })

            if userRes and userRes.StatusCode == 200 then
                local data = HttpService:JSONDecode(userRes.Body).data
                for _, uData in ipairs(data) do
                    local matchedName = nil
                    for _, name in ipairs(targetUsers) do
                        if name:lower() == uData.name:lower() then
                            matchedName = name
                            break
                        end
                    end
                    
                    if matchedName then
                        local pData = monitoredPlayers[matchedName]
                        if pData then
                            pData.UserId = uData.id
                            pData.AvatarImg.Image = string.format("https://www.roproxy.com/headshot-thumbnail/image?userId=%s&width=150&height=150&format=png", tostring(uData.id))
                            pData.SavedDisplayName = uData.displayName
                            pData.StaticTextTemplate = "暱稱: " .. uData.displayName .. "\n名稱: " .. uData.name .. "\nID: " .. tostring(uData.id)
                            pData.InfoLabel.Text = pData.StaticTextTemplate
                            pData.isFetched = true
                        end
                    end
                end
            end
            task.wait(0.1) -- 批次間微小冷卻，確保 Roproxy 完全不當機
        end
    end)
end

