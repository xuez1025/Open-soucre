local function handleSearch()
    local text = SearchBox.Text:gsub("%s+", "")
    if text == "" then return end
    
    if tonumber(text) then
        showDetailByUserId(tonumber(text))
    else
        DetailText.Text = "⚡ 正在檢索該玩家 ID 對應檔案..."
        task.spawn(function()
            local res = sendRequest({
                Url = "https://users.roproxy.com/v1/usernames/users",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({ usernames = { text }, excludeBannedUsers = false })
            })
            if res and res.StatusCode == 200 then
                local data = HttpService:JSONDecode(res.Body).data[1]
                if data then
                    showDetailByUserId(data.id)
                else
                    DetailText.Text = "❌ 資料庫中查無此玩家，請確認拼字。"
                end
            else
                DetailText.Text = "❌ 遠端 API 請求失敗。"
            end
        end)
    end
end

SearchBtn.MouseButton1Click:Connect(handleSearch)
