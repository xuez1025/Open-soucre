-- 新增按鈕邏輯：動態複製 (網址 或 JobID)
---------------------------------------------
CopyBtn.MouseButton1Click:Connect(function()
    if currentDataType == "None" or UrlInput.Text == "" then
        ResultText.Text = "【系統提示】目前尚未生成任何監控數據，無法複製。"
        return
    end

    if currentDataType == "UserData" then
        local success = copyToClipboard(UrlInput.Text)
        if success then
            CopyBtn.Text = "✅ 複製成功！"
            task.delay(1.5, function() CopyBtn.Text = "📋 複製網址" end)
        else
            ResultText.Text = "【複製失敗】您的執行器不支援剪貼簿函數。"
        end
    elseif currentDataType == "Presence" then
        if lastRawResponse == "" then
            ResultText.Text = "【系統提示】尚未獲取到在線狀態數據，請稍候再試。"
            return
        end

        local successParse, decoded = pcall(function() return HttpService:JSONDecode(lastRawResponse) end)
        if successParse and decoded and decoded.userPresences and decoded.userPresences[1] then
            local jobId = decoded.userPresences[1].gameId
            
            if jobId and jobId ~= "" and jobId ~= "null" then
                local successCopy = copyToClipboard(tostring(jobId))
                if successCopy then
                    CopyBtn.Text = "✅ JobID已複製"
                    task.delay(1.5, function() CopyBtn.Text = "📋 複製JobID" end)
                else
                    ResultText.Text = "【複製失敗】您的執行器不支援剪貼簿函數。"
                end
            else
                ResultText.Text = "【複製提示】目前該玩家不在遊戲中（或為私人伺服器），沒有可用的 JobId (gameId)。"
            end
        else
            ResultText.Text = "【解析失敗】無法從回傳的 API 數據中提取 JobId。"
        end
    end
end)

