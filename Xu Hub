local currentSilentAimTarget = nil
local currentSilentAimTargetPos = nil

local function GetClosestTarget()
    local closest = nil
    local shortest = math.huge

    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    local function check(character)
        if not IsAlive(character) then return end
        local part = character:FindFirstChild("HumanoidRootPart")
        if not part then return end

        local dist = (part.Position - myRoot.Position).Magnitude

        local passFOV = true
        if _G.G_SilentAimShowFOV then
            local origin = GetSilentAimOrigin()
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local screenDist = (Vector2.new(pos.X, pos.Y) - origin).Magnitude
                if screenDist > (_G.G_SilentAimFOV or 150) then
                    passFOV = false
                end
            else
                passFOV = false
            end
        end

        if passFOV and dist < shortest then
            closest = part
            shortest = dist
        end
    end

    if _G.G_SilentAimTargetPlayers then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if not _G.G_SilentAimTeamCheck or IsSilentAimEnemy(player) then
                    check(player.Character)
                end
            end
        end
    end

    if _G.G_SilentAimTargetMobs then
        local enemiesFolder = workspace:FindFirstChild("Enemies")
        if enemiesFolder then
            for _, enemy in ipairs(enemiesFolder:GetChildren()) do
                check(enemy)
            end
        end
    end
    return closest
end

if not disableHook then
    pcall(function()
        local MouseModuleInstance = ReplicatedStorage:FindFirstChild("Mouse")
        if MouseModuleInstance then
            local MouseModule = require(MouseModuleInstance)
            if typeof(MouseModule) == "table" then
                local realStore = {}
                realStore.Hit = rawget(MouseModule, "Hit")
                realStore.Target = rawget(MouseModule, "Target")

                local mmt = getrawmetatable(MouseModule)
                if mmt and not isreadonly(mmt) then
                    setreadonly(mmt, false)
                else
                    mmt = {}
                    setmetatable(MouseModule, mmt)
                end

                rawset(MouseModule, "Hit", nil)
                rawset(MouseModule, "Target", nil)

                mmt.__index = function(self, key)
                    if key == "Hit" then
                        if _G.G_SilentAimEnabled and currentSilentAimTargetPos then
                            return CFrame.new(currentSilentAimTargetPos)
                        end
                        return realStore.Hit
                    elseif key == "Target" then
                        if _G.G_SilentAimEnabled and currentSilentAimTarget then
                            return currentSilentAimTarget
                        end
                        return realStore.Target
                    end
                    return rawget(self, key)
                end

                mmt.__newindex = function(self, key, value)
                    if key == "Hit" or key == "Target" then
                        realStore[key] = value
                    else
                        rawset(self, key, value)
                    end
                end
                setreadonly(mmt, true)
            end
        end
    end)

    local oldIndex
    oldIndex = hookmetamethod(game, "__index", function(self, key)
        if not checkcaller() and _G.G_SilentAimEnabled and currentSilentAimTargetPos and self == mouse then
            local targetPos = currentSilentAimTargetPos
            local camPos = Camera.CFrame.Position

            if key == "Hit" then
                return CFrame.new(targetPos)
            elseif key == "Target" then
                return currentSilentAimTarget
            elseif key == "UnitRay" then
                return Ray.new(camPos, (targetPos - camPos).Unit)
            elseif key == "Origin" then
                return camPos
            elseif key == "Direction" then
                return (targetPos - camPos).Unit
            end
        end
        return oldIndex(self, key)
    end)
end

_G.G_SilentAimLoop = RunService.RenderStepped:Connect(function()
    local origin = GetSilentAimOrigin()

    if _G.G_SilentAimShowFOV then
        FovCircle.Visible = true
        FovCircle.Radius = _G.G_SilentAimFOV or 150
        FovCircle.Position = origin
        FovCircle.Thickness = _G.G_SilentAimFOVThickness or 2
        FovCircle.Transparency = _G.G_SilentAimFOVTransparency or 1
    else
        FovCircle.Visible = false
    end

    currentSilentAimTarget = GetClosestTarget()
    currentSilentAimTargetPos = currentSilentAimTarget and currentSilentAimTarget.Position or nil
    _G.G_SilentAimTargetPos = currentSilentAimTargetPos

    if _G.G_SilentAimShowLine and currentSilentAimTargetPos then
        local pos, onScreen = Camera:WorldToViewportPoint(currentSilentAimTargetPos)
        if onScreen then
            local clockTime = os.clock()
            local targetScreenPos = Vector2.new(pos.X, pos.Y)
            local lineVector = targetScreenPos - origin

            local laserColor = BaseLaserColor
            local glowColorOuter = BaseLaserColor
            local glowColorMid = BaseLaserColor

            if RainbowSnapLine then
                local baseHue = (clockTime * LaserPulseSpeed * 0.04) % 1
                laserColor = Color3.fromHSV(baseHue, 0.85, 1)
                glowColorMid = Color3.fromHSV((baseHue + 0.04) % 1, 0.85, 0.95)
                glowColorOuter = Color3.fromHSV((baseHue + 0.08) % 1, 0.80, 0.90)
            else
                local lerpFactor = (math.sin(clockTime * LaserPulseSpeed) + 1) / 2
                laserColor = BaseLaserColor:Lerp(Color3.fromRGB(255, 230, 240), lerpFactor * 0.2)
            end

            local pulseWave = math.sin(clockTime * LaserPulseSpeed)
            local cosWave = math.cos(clockTime * LaserPulseSpeed * 1.3)
            local glowAlphaMultiplier = 0.75 + (pulseWave * 0.25)

            SnapLineGlowOuter.Visible = true
            SnapLineGlowOuter.From = origin
            SnapLineGlowOuter.To = targetScreenPos
            SnapLineGlowOuter.Color = glowColorOuter
            SnapLineGlowOuter.Thickness = SnapLineThickness * 8.5
            SnapLineGlowOuter.Transparency = 0.10 * glowAlphaMultiplier

            SnapLineGlowMid.Visible = true
            SnapLineGlowMid.From = origin
            SnapLineGlowMid.To = targetScreenPos
            SnapLineGlowMid.Color = glowColorMid
            SnapLineGlowMid.Thickness = SnapLineThickness * 4.0
            SnapLineGlowMid.Transparency = 0.30 * glowAlphaMultiplier

            SnapLineGlow.Visible = true
            SnapLineGlow.From = origin
            SnapLineGlow.To = targetScreenPos
            SnapLineGlow.Color = laserColor
            SnapLineGlow.Thickness = SnapLineThickness * 1.8
            SnapLineGlow.Transparency = 0.70 * glowAlphaMultiplier

            SnapLineCore.Visible = true
            SnapLineCore.From = origin
            SnapLineCore.To = targetScreenPos
            SnapLineCore.Color = RainbowSnapLine and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(255, 215, 235)
            SnapLineCore.Thickness = SnapLineThickness * 0.55
            SnapLineCore.Transparency = 1.0

            local progress1 = (clockTime * 0.75) % 1
            LaserBead1.Visible = true
            LaserBead1.Position = origin + (lineVector * progress1)
            LaserBead1.Radius = SnapLineThickness * (1.5 + math.sin(clockTime * 15) * 0.4)
            LaserBead1.Color = Color3.fromRGB(255, 255, 255)
            LaserBead1.Transparency = 0.85 * (1 - progress1)

