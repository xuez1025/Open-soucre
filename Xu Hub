local frameCount = 0
local lastUpdate = os.clock()
local currentFps = 0

RunService.RenderStepped:Connect(function()
    frameCount += 1
    local now = os.clock()
    local deltaTime = now - lastUpdate
    
    if deltaTime >= 1 then
        currentFps = frameCount / deltaTime
        frameCount = 0
        lastUpdate = now
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        
        if FPSSection then 
            FPSSection:SetTitle(string.format("FPS: %.0f/s", currentFps)) 
        end

        if PlayerSection then 
            local maxPlayers = Players.MaxPlayers or 20
            PlayerSection:SetTitle(string.format("Players: %d/%d", #Players:GetPlayers(), maxPlayers)) 
        end

        if TimeSection then 
            local t = os.date("*t")
            TimeSection:SetTitle(string.format("Local Time: %04d-%02d-%02d %02d:%02d:%02d",
                t.year, t.month, t.day, t.hour, t.min, t.sec))
        end

        if PingSection and LocalPlayer then 
            local ping = LocalPlayer:GetNetworkPing() * 1000
            PingSection:SetTitle(string.format("Ping: %.0f ms", ping))
        end

        if GameTimeSection then 
            local gt = math.floor(Workspace.DistributedGameTime + 0.5)
            GameTimeSection:SetTitle(string.format("Game Time: %02d:%02d:%02d",
                math.floor(gt / 3600), math.floor(gt / 60) % 60, gt % 60))
        end
    end
end)

