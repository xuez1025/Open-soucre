-- Camera Zoom
local function SetZoom(value)
    value = tonumber(value)
    if not value then return end
    
    -- 將數值四捨五入到最接近的 STEP
    value = math.floor((value / _G.ZoomStep) + 0.5) * _G.ZoomStep
    -- 限制在範圍內
    value = math.clamp(value, _G.MinZoom, _G.MaxZoom)
    
    _G.CurrentZoom = value
    
    -- 確保 LocalPlayer 存在
    if LocalPlayer then
        -- 1. 將最小縮放距離固定在最貼近玩家的位置（例如原本的 100 或是遊戲預設的 0.5）
        -- 這樣你才能隨時用滾輪拉到最近
        LocalPlayer.CameraMinZoomDistance = 0.5 
        
        -- 2. 將最大縮放距離綁定到 Slider 的數值
        -- 這樣你就可以透過滾輪，在 0.5 到「Slider 設定的值」之間自由縮放
        LocalPlayer.CameraMaxZoomDistance = value
    end
end

