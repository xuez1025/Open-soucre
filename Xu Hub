_G.TP_CurrentToken = 0

local function ForceStopAllMovement()
    _G.TP_CurrentToken = _G.TP_CurrentToken + 1
    
    if _G.TP_ActiveTween then
        _G.TP_ActiveTween:Cancel()
        _G.TP_ActiveTween = nil
    end
    
    -- 停止傳送時關閉全域 Noclip
    _G.SetNoclipState(false)

    local char = LocalPlayer.Character
    if char then
        local HRP = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        if HRP then
            HRP.AssemblyLinearVelocity = Vector3.zero
            HRP.AssemblyAngularVelocity = Vector3.zero
            local bodyVelocity = HRP:FindFirstChild("TP_AntiFall")
            if bodyVelocity then bodyVelocity:Destroy() end
        end
        
        if hum then
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end

local function ExecuteTween(targetCFrame, currentToken)
    local char = LocalPlayer.Character
    local HRP = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not HRP or not hum then return false end

    local bodyVelocity = HRP:FindFirstChild("TP_AntiFall")
    if not bodyVelocity then
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Name = "TP_AntiFall"
        bodyVelocity.Parent = HRP
    end
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Velocity = Vector3.zero

    hum.PlatformStand = true
    hum:ChangeState(Enum.HumanoidStateType.Physics)
    
    -- 移動開始呼叫全域控制啟用 Noclip
    _G.SetNoclipState(true)

    local distance = (targetCFrame.Position - HRP.Position).Magnitude
    local speed = 300
    if distance < 150 then speed = 600
    elseif distance < 250 then speed = 450
    elseif distance < 500 then speed = 400
    elseif distance < 750 then speed = 300
    end

    if _G.TP_ActiveTween then _G.TP_ActiveTween:Cancel() end

    local tweenInfo = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
    _G.TP_ActiveTween = TweenService:Create(HRP, tweenInfo, {CFrame = targetCFrame})
    _G.TP_ActiveTween:Play()
    
    _G.TP_ActiveTween.Completed:Wait()

    if _G.TP_CurrentToken ~= currentToken then
        return false 
    end
    return true
end

local function TeleportTo(DataBlock)
    ForceStopAllMovement()
    task.wait(0.02) 
    
    local myToken = _G.TP_CurrentToken 
    
    task.spawn(function()
        local char = LocalPlayer.Character
        local HRP = char and char:FindFirstChild("HumanoidRootPart")
        if not HRP then return end

        local TargetPos = DataBlock.Target
        local IntermediatePos = DataBlock.Intermediate
        local CurrentDistance = (TargetPos.Position - HRP.Position).Magnitude

        if CurrentDistance > 300 and IntermediatePos then
            -- 改用全域 Noclip 控制
            _G.SetNoclipState(true)
            HRP.CFrame = IntermediatePos
            
            local startTime = os.clock()
            while (os.clock() - startTime) < 1 do
                if _G.TP_CurrentToken ~= myToken then return end 
                task.wait(0.05)
            end
        end

        while _G.TP_CurrentToken == myToken and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") do
            local currentHRP = LocalPlayer.Character.HumanoidRootPart
            local Dist = (TargetPos.Position - currentHRP.Position).Magnitude
            
            if Dist < 4 then break end 

            local success = ExecuteTween(TargetPos, myToken)
            if not success then return end 

            task.wait(0.05)
        end

        if _G.TP_CurrentToken == myToken then
            ForceStopAllMovement()
        end
    end)
end

