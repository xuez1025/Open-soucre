-- 補間動畫輔助函式
local function tween(obj, properties, time, easingStyle)
    TweenService:Create(obj, TweenInfo.new(time or 0.2, easingStyle or Enum.EasingStyle.Quad, Enum.EasingDirection.Out), properties):Play()
end

-- 動態按鈕互動 (Hover & Click 特效)
local function setupInteractions(btn, baseColor, hoverColor)
    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundColor3 = hoverColor, Size = btn.Size + UDim2.new(0, 2, 0, 2), Position = btn.Position - UDim2.new(0, 1, 0, 1)}, 0.15)
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundColor3 = baseColor, Size = btn.Size - UDim2.new(0, 2, 0, 2), Position = btn.Position + UDim2.new(0, 1, 0, 1)}, 0.15)
    end)
    btn.MouseButton1Down:Connect(function()
        tween(btn, {Size = btn.Size - UDim2.new(0, 4, 0, 4), Position = btn.Position + UDim2.new(0, 2, 0, 2)}, 0.08)
    end)
    btn.MouseButton1Up:Connect(function()
        tween(btn, {Size = btn.Size + UDim2.new(0, 4, 0, 4), Position = btn.Position - UDim2.new(0, 2, 0, 2)}, 0.08)
    end)
end

