-- ─── Command registry ─────────────────────────────────────────────────────────
-- This is the piece the original "UI only" file was missing: a place to plug
-- in actual commands. RegisterCommand() builds one button in CMDsF (the
-- scrolling list under the bar) and wires the Cmdbar so typing the command
-- name + Enter runs it.

Commands = {}

-- registerCommand(names, desc, usage, callback)
--   names    : table of strings, e.g. {"fly", "f"}  (first entry is shown in the list)
--   desc     : short tooltip description shown on hover
--   usage    : example usage shown in the tooltip, e.g. "fly [speed]"
--   callback : function(args) ... end   -- args is a table of words after the command name
function registerCommand(names, desc, usage, callback)
	local primary = names[1]
	for _, alias in ipairs(names) do
		Commands[alias:lower()] = callback
	end

	local entry = Instance.new("TextButton")
	entry.Name = primary
	entry.Parent = CMDsF
	entry.BackgroundTransparency = 1
	entry.BorderSizePixel = 0
	entry.Size = UDim2.new(0, 235, 0, 20)
	entry.Font = Enum.Font.SourceSans
	entry.TextSize = 18
	entry.Text = primary
	entry.TextColor3 = Color3.new(1, 1, 1)
	entry.TextXAlignment = Enum.TextXAlignment.Left
	entry.ZIndex = 10
	entry:SetAttribute("Title", usage or primary)
	entry:SetAttribute("Desc", desc or "")
	table.insert(text1, entry)

	entry.MouseButton1Click:Connect(function()
		Cmdbar.Text = primary .. " "
		Cmdbar:CaptureFocus()
	end)

	CMDsF.CanvasSize = UDim2.new(0, 0, 0, cmdListLayout.AbsoluteContentSize.Y)
	return entry
end

-- runCommand(input) — parses "name arg1 arg2 ..." and dispatches to Commands
function runCommand(input)
	input = input:gsub("^%s+", ""):gsub("%s+$", "")
	if input == "" then return end
	local words = {}
	for word in input:gmatch("%S+") do table.insert(words, word) end
	local name = table.remove(words, 1):lower()
	local fn = Commands[name]
	if fn then
		local ok, err = pcall(fn, words)
		if not ok then
			notify("Command Error", name .. ": " .. tostring(err))
		end
	else
		notify("Unknown Command", "'" .. name .. "' is not a registered command")
	end
end

Cmdbar.FocusLost:Connect(function(enteredViaReturn)
	if enteredViaReturn then
		runCommand(Cmdbar.Text)
	end
end)

