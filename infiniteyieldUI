function updateColors(color, ctype)
	if ctype == shade1 then
		for _,v in pairs(shade1) do v.BackgroundColor3 = color end
		currentShade1 = color
	elseif ctype == shade2 then
		for _,v in pairs(shade2) do v.BackgroundColor3 = color end
