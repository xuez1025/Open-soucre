_G.HiddenGameUIsList = _G.HiddenGameUIsList or {}
_G.HideGameUIState = false

local function ToggleGameUI(state)
    _G.HideGameUIState = state
    if state then
        table.clear(_G.HiddenGameUIsList)
        for _, gui in ipairs(playerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Enabled == true and gui.Name ~= "XuPremiumLoading" then
                table.insert(_G.HiddenGameUIsList, gui)
                gui.Enabled = false
            end
        end
    else
        for _, gui in ipairs(_G.HiddenGameUIsList) do
            if gui and gui.Parent then
                gui.Enabled = true
            end
        end
        table.clear(_G.HiddenGameUIsList)
    end
end

