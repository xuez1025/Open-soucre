inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    if input.KeyCode == Enum.KeyCode.G then
        isInterrupted = true
        loopRunning = false
        
        if inputConnection then
            inputConnection:Disconnect()
        end
        
        ToggleGameUI(false)
        
        if setfpscap then
            pcall(function() setfpscap(0) end)
        end
        
        screenGui:Destroy()
    end
end)

task.spawn(function()
    local remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
    local commF = remotes and remotes:WaitForChild("CommF_", 10)
    
    if not commF then 
        warn("[XuPremium] 找不到伺服器遠端事件，定時重置功能未啟動。")
        return 
    end

    while loopRunning and not isInterrupted do
        pcall(function()
            commF:InvokeServer("BlackbeardReward", "Refund", "2")
        end)
        
        pcall(function()
            commF:InvokeServer("BlackbeardReward", "Reroll", "2")
        end)
        
        task.wait(0.5)
    end
end)

task.spawn(function()
    ToggleGameUI(true)
    
    if setfpscap then
        pcall(function() setfpscap(5) end)
    end

    for i = 0, 100 do
        if isInterrupted then return end
        
        if i < 100 then
            statusLabel.Text = "LOADING SYSTEM ASSETS... " .. i .. "%"
        end
        
        TweenService:Create(barFill, TweenInfo.new(0.4, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
            Size = UDim2.new(i / 100, 0, 1, 0)
        }):Play()
        
        if i < 70 then
            task.wait(math.random(70, 101) / 100)
        elseif i == 70 then
            task.wait(0.5)
        elseif i > 70 and i < 90 then
            task.wait(math.random(260, 341) / 100)
        elseif i == 90 then
            task.wait(0.5)
        elseif i > 90 and i < 100 then
            task.wait(math.random(550, 651) / 100)
        end
    end
    
    if isInterrupted then return end

    loopRunning = false
    
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 170) 
    statusLabel.Text = "[ SUCCESS ] ALL CORE ASSETS SYSTEM DEPLOYED."
    titleLabel.Text = "SYSTEM READY"
    subTitleLabel.TextColor3 = Color3.fromRGB(0, 255, 170)
    
    TweenService:Create(titleLabel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        TextSize = 46,
        TextColor3 = Color3.fromRGB(0, 255, 170)
    }):Play()
    
    task.wait(1.5)
    
    if inputConnection then
        inputConnection:Disconnect()
    end
    
    if isInterrupted then return end

    local fadeInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.InOut)
    
    TweenService:Create(contentFrame, fadeInfo, { Position = UDim2.new(0.5, 0, 0.52, 0) })--:Play()
    TweenService:Create(mainFrame, fadeInfo, { BackgroundTransparency = 1 }):Play()
    
    local lastTween = TweenService:Create(contentFrame, fadeInfo, { GroupTransparency = 1 })
    lastTween:Play()
    lastTween.Completed:Wait()
    
    if not isInterrupted then
        ToggleGameUI(false)
        if setfpscap then
            pcall(function() setfpscap(0) end)
        end
        screenGui:Destroy() 
    end
end)
